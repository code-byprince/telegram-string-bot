# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# Admin IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Rate Limiting
RATE_LIMIT=3
RATE_LIMIT_PERIOD=300  # seconds

# Session Timeout
SESSION_TIMEOUT=300  # seconds

# Logging
LOG_LEVEL=INFO

# Flask Web Server
PORT=5000
HOST=0.0.0.0

# Optional: Default API credentials for testing
API_ID=6
API_HASH=your_api_hash_here
