    F -->|Yes| G[Enter 2FA Password]
    F -->|No| H[Generate Session]
    G --> H
    H --> I[Send String Session]
    I --> J[Auto-Delete after 10 mins]
    
    style A fill:#FF6B6B
    style H fill:#51CF66
    style I fill:#4DABF7
    style J fill:#FFD93D
