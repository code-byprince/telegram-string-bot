# ============================================
# REQUIRED VARIABLES (Inke bina bot nahi chalega)
# ============================================

# 1. BOT_TOKEN - Telegram Bot ka token
# Jaise: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
BOT_TOKEN=7584930211:AAGhIjKlMnOpQrStUvWxYz1234567890

# 2. ADMIN_IDS - Aapki Telegram ID (comma-separated)
# Jaise: 123456789 (ek admin) ya 123456789,987654321 (multiple admins)
ADMIN_IDS=123456789


# ============================================
# OPTIONAL VARIABLES (Sab add karein - recommended)
# ============================================

# 3. API_ID - Telegram API ID (testing ke liye)
# Jaise: 6 (default) ya 123456 (real API ID)
API_ID=6

# 4. API_HASH - Telegram API Hash (testing ke liye)
# Jaise: your_api_hash_here (default) ya real hash
API_HASH=your_api_hash_here

# 5. RATE_LIMIT - Ek user kitni baar generate kar sakta hai
# Jaise: 3 (default) - matlab 3 baar
RATE_LIMIT=3

# 6. RATE_LIMIT_PERIOD - Rate limit kitne seconds mein reset hogi
# Jaise: 300 (default) - matlab 5 minutes
RATE_LIMIT_PERIOD=300

# 7. SESSION_TIMEOUT - User kitne der tak inactive rah sakta hai
# Jaise: 300 (default) - matlab 5 minutes
SESSION_TIMEOUT=300

# 8. LOG_LEVEL - Logging level
# Jaise: INFO (default) - options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# 9. PORT - Flask web server port
# Jaise: 5000 (default) - Render pe auto detect
PORT=5000

# 10. HOST - Flask web server host
# Jaise: 0.0.0.0 (default) - production ke liye
HOST=0.0.0.0
